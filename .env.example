# Supabase project: cptyjloveecusgvituzo
# Dashboard: https://supabase.com/dashboard/project/cptyjloveecusgvituzo
# API URL: https://cptyjloveecusgvituzo.supabase.co
# Copy to .env.local and fill keys (get anon key via Supabase MCP get_publishable_keys or Dashboard → API)
NEXT_PUBLIC_SUPABASE_URL=https://cptyjloveecusgvituzo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# From Supabase Dashboard → Project Settings → API → service_role (not exposed via MCP)
SUPABASE_SERVICE_ROLE_KEY=
# CLI link / hosted migration push (gitignored .env.local only — never commit)
# PAT: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# DB password: Dashboard → Project Settings → Database (reset if unknown)
SUPABASE_DB_PASSWORD=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Platform GMV fee fraction (0.4%); code caps at $2.00 per charge
STRIPE_PLATFORM_FEE_PCT=0.004
# Stripe Billing Price IDs for Starter ($99) and Growth ($199)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
SESSION_JWT_SECRET=
# Honor X-Forwarded-For / X-Real-IP for rate limits. On Vercel this defaults on (VERCEL=1).
# Set TRUST_PROXY=0 only for local direct Node without a reverse proxy.
# TRUST_PROXY=1
# Force in-memory rate limits (tests / emergency). Production uses Postgres api_rate_limits.
# RATE_LIMIT_BACKEND=memory
NEXT_PUBLIC_APP_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_SUPABASE_URL=https://cptyjloveecusgvituzo.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Operator support (mailto fallback; optional Crisp chat)
SUPPORT_EMAIL=support@tableflow.app
NEXT_PUBLIC_SUPPORT_EMAIL=support@tableflow.app
NEXT_PUBLIC_CRISP_WEBSITE_ID=
# Anthropic API key for AI agents (upsell, forecasts, insights). Optional — stubs return empty when unset.
ANTHROPIC_API_KEY=
# Resend (lifecycle emails). Optional — emails no-op when unset.
RESEND_API_KEY=
RESEND_FROM_EMAIL=TableFlow <onboarding@tableflow.app>
# Sentry (web). Optional — disabled when unset.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# When 1, venues charge the platform Stripe account (no Connect). Use for staging until Connect is enabled.
STRIPE_PLATFORM_CHARGES=0
