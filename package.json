{
  "name": "tableflow",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check && tsc -p tsconfig.scripts.json --noEmit",
    "test": "turbo test",
    "db:push": "supabase db push",
    "db:seed": "supabase db reset --linked",
    "sync:platform-config": "tsx scripts/sync-platform-config.ts"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "mobile": {
      "react": "19.1.0",
      "react-native": "0.81.5",
      "react-native-safe-area-context": "~5.6.0",
      "react-native-screens": "~4.16.0",
      "expo": "~54.0.36",
      "expo-camera": "~17.0.7",
      "expo-font": "~14.0.7",
      "expo-haptics": "~15.0.6",
      "expo-notifications": "~0.32.10",
      "expo-secure-store": "~15.0.6",
      "expo-status-bar": "~3.0.7",
      "@stripe/stripe-react-native": "0.50.3"
    }
  }
}
